    "components": {
        "schemas": {
            "Product": {
                "type": "object",
                "required": [
                    "title",
                    "price",
                    "categoryId",
                    "stock"
                ],
                "properties": {
                    "title": {
                        "type": "string"
                    }, 
                    "description": {
                        "type": "string"
                    },
                    "price": {
                        "type": "number"
                    },
                    "categoryId": {
                        "type": "integer"
                    },
                    "image": {
                        "type": "string",
                        "format": "uri"
                    },
                    "stock": {
                        "type": "integer"
                    }
                }                
            },
            "Error": {
                "type": "object",
                "required": ["error", "status", "message", "timestamp"],
                "properties": {
                    "error": {
                        "type": "boolean"
                    },
                    "status": {
                        "type": "integer"
                    },
                    "message": {
                        "type": "string"
                    },
                    "timestamp":{
                        "type": "string",
                        "format": "date-time"
                    }
                }
            },
            "UpdateProductRequest": {
                "type": "object",
                "properties": {
                    "title": {
                        "type": "string"
                    }, 
                    "description": {
                        "type": "string"
                    },
                    "price": {
                        "type": "number"
                    },
                    "categoryId": {
                        "type": "integer"
                    },
                    "image": {
                        "type": "string",
                        "format": "uri"
                    },
                    "stock": {
                        "type": "integer"
                    }
                }
            },
            "SuccessMessage": {
                "type": "object",
                "required": ["message"],
                "properties": {
                    "message": {
                        "type": "string"
                    }
                }
            },
            "CategoryResponse": {
                "type": "object",
                "required": ["name", "id"],
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "id": {
                        "type": "integer"
                    }
                }
            },
            "CreateCategoryRequest": {
                "type": "object",
                "required": ["name"],
                "properties": {
                    "name": {
                        "type": "string"
                    }
                }
